# ================================
# Unity - Push ONLY important files
# ================================

# Ignore EVERYTHING by default
*

# ----------------
# Allow important Unity folders
# ----------------
!Assets/
!Assets/**
!Packages/
!Packages/**
!ProjectSettings/
!ProjectSettings/**
!.gitignore

# ----------------
# Explicit ignores (safety)
# ----------------
Library/
Temp/
Logs/
Obj/
Build/
Builds/
UserSettings/

# ----------------
# IDE / OS junk
# ----------------
.vs/
.gradle/
.consulo/
*.csproj
*.sln
*.user
*.tmp
*.log
*.pidb
*.pdb
*.mdb
*.opendb
*.VC.db
.DS_Store
Thumbs.db

# ----------------
# Build outputs (forced ignore)
# ----------------
*.apk
*.aab
*.app
*.exe
*.unitypackage

# ----------------
# Blender backup files
# ----------------
*.blend1
*.blend1.meta
