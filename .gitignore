# =========================
# Unity Minimal Clean Setup
# Keeps only:
#   Assets/
#   ProjectSettings/
#   Packages/
# =========================

# Ignore everything at root
/*

# Allow required Unity folders
!/Assets/
!/ProjectSettings/
!/Packages/

# Allow their contents
!/Assets/**
!/ProjectSettings/**
!/Packages/**


# =========================
# Unity Generated Folders
# =========================

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/


# =========================
# IDE / Editor Files
# =========================

.vs/
.idea/
.consulo/
.gradle/
ExportedObj/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.DotSettings.user


# =========================
# OS Generated Files
# =========================

.DS_Store
Thumbs.db
desktop.ini


# =========================
# Build Files
# =========================

*.apk
*.aab
*.app
*.exe
*.unitypackage
*.unitypackage.meta


# =========================
# Crash & Logs
# =========================

sysinfo.txt
mono_crash.*
crashlytics-build.properties


# =========================
# Addressables
# =========================

/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*


# =========================
# Visual Scripting
# =========================

/[Aa]ssets/Unity.VisualScripting.Generated/


# =========================
# Test Runner
# =========================

/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
